{
  "name": "browsemind",
  "version": "1.0.0",
  "private": true,
  "description": "BrowseMind — Price Tracking & Product Intelligence Platform",
  "scripts": {
    "dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "build": "npm run build --prefix frontend",
    "preview": "npm run preview --prefix frontend",
    "start:backend": "npm run dev --prefix backend",
    "start:frontend": "npm run dev --prefix frontend",
    "start": "npm run start --prefix backend",
    "install:all": "npm install --prefix frontend && npm install --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
